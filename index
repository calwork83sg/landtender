        type: 'line',
        data: {
            labels: loanMonths,
            datasets: [
                {
                    label: 'Land Loan Balance (S$M)',
                    data: landBalances,
                    borderColor: '#c53030',
                    backgroundColor: 'rgba(197, 48, 48, 0.1)',
                    fill: true,
                    tension: 0.3
                },
                {
                    label: 'Construction Loan Balance (S$M)',
                    data: constBalances,
                    borderColor: '#2c5282',
                    backgroundColor: 'rgba(44, 82, 130, 0.1)',
                    fill: true,
                    tension: 0.3
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                title: { display: true, text: 'Loan Amortisation (First 60 Months)', font: { size: 14 } },
                legend: { position: 'top' }
            },
            scales: {
                y: { title: { display: true, text: 'Balance (S$M)' } }
            }
        }
    });
}

