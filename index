<script>
let currentScenario = 'medium';
let cashflowData = [];
let chartInstances = {};

function setScenario(scenario) {
    currentScenario = scenario;
    document.querySelectorAll('.scenario-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelector(`[data-scenario="${scenario}"]`).classList.add('active');

    const descs = {
        conservative: '<strong>Conservative Case:</strong> Assumes 75% occupancy, 1.5% rental growth, 10% construction cost overrun buffer, and 50bps higher interest rates. Use this for risk-averse bidding or when market uncertainty is high.',
        medium: '<strong>Medium Case:</strong> Base assumptions with moderate occupancy (85%), stable rental growth (2.5% p.a.), and standard construction costs. This represents the most probable outcome.',
        aggressive: '<strong>Aggressive Case:</strong> Assumes 95% occupancy, 3.5% rental growth, no cost overruns, and potential for rent premium. Use only if you have strong operational track record and market conviction.'
    };
    document.getElementById('scenarioDesc').innerHTML = descs[scenario];
}

function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');

    if (tab === 'chart' && cashflowData.length > 0) {
        setTimeout(renderCharts, 50);
    }
}

function formatCurrency(num) {
    if (num === undefined || num === null) return '-';
    if (Math.abs(num) >= 1e9) return 'S$' + (num / 1e9).toFixed(2) + 'B';
    if (Math.abs(num) >= 1e6) return 'S$' + (num / 1e6).toFixed(2) + 'M';
    if (Math.abs(num) >= 1e3) return 'S$' + (num / 1e3).toFixed(1) + 'K';
    return 'S$' + num.toFixed(0);
}

function formatNumber(num) {
    return num.toLocaleString('en-SG', { maximumFractionDigits: 0 });
}

function getInputs() {
    const get = id => parseFloat(document.getElementById(id).value) || 0;
    return {
        landSize: get('landSize'),
        plotRatio: get('plotRatio'),
        leasehold: get('leasehold'),
        numPax: get('numPax'),
        occupancy: get('occupancy') / 100,
        rentalRate: get('rentalRate'),
        constructionCost: get('constructionCost'),
        constructionPeriod: get('constructionPeriod'),
        profFees: get('profFees') / 100,
        contingency: get('contingency') / 100,
        otherDevCosts: get('otherDevCosts'),
        equity: get('equity'),
        landLTV: get('landLTV') / 100,
        landRate: get('landRate') / 100,
        landTenor: get('landTenor'),
        constructionLTV: get('constructionLTV') / 100,
        constructionRate: get('constructionRate') / 100,
        constructionTenor: get('constructionTenor'),
        opexPerPax: get('opexPerPax'),
        fixedOpex: get('fixedOpex'),
        rentEscalation: get('rentEscalation') / 100,
        opexEscalation: get('opexEscalation') / 100,
        shLoanRate: get('shLoanRate') / 100,
        shLoanAmount: get('shLoanAmount'),
        targetIRR: get('targetIRR') / 100,
        exitCapRate: get('exitCapRate') / 100
    };
}

function applyScenario(inputs, scenario) {
    const i = { ...inputs };
    if (scenario === 'conservative') {
        i.occupancy = Math.max(0.70, i.occupancy - 0.10);
        i.rentEscalation = Math.max(0, i.rentEscalation - 0.01);
        i.constructionCost *= 1.08;
        i.landRate += 0.005;
        i.constructionRate += 0.005;
        i.opexPerPax *= 1.05;
    } else if (scenario === 'aggressive') {
        i.occupancy = Math.min(0.98, i.occupancy + 0.10);
        i.rentEscalation += 0.01;
        i.constructionCost *= 0.95;
        i.rentalRate *= 1.05;
        i.opexPerPax *= 0.95;
    }
    return i;
}

function calculateLoanSchedule(principal, annualRate, totalMonths, startMonth = 0) {
    const monthlyRate = annualRate / 12;
    const monthlyPayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, totalMonths)) / (Math.pow(1 + monthlyRate, totalMonths) - 1);
    const schedule = [];
    let balance = principal;

    for (let m = 1; m <= totalMonths; m++) {
        const interest = balance * monthlyRate;
        const principalPaid = monthlyPayment - interest;
        balance = Math.max(0, balance - principalPaid);
        schedule.push({
            month: startMonth + m,
            payment: monthlyPayment,
            interest: interest,
            principal: principalPaid,
            balance: balance
        });
    }
    return schedule;
}

function calculateAll() {
    document.getElementById('loading').classList.add('active');
    document.getElementById('results').classList.remove('active');

    setTimeout(() => {
        const baseInputs = getInputs();

        // Calculate for all three scenarios
        const scenarios = {};
        ['conservative', 'medium', 'aggressive'].forEach(scen => {
            const inputs = applyScenario(baseInputs, scen);
            scenarios[scen] = calculateScenario(inputs, scen);
        });

        // Use medium case for cashflow display
        cashflowData = scenarios.medium;

        displayPrices(scenarios, baseInputs);
        displaySummary(scenarios.medium, baseInputs);
        displayCashflow(scenarios.medium);
        displayLoanSchedule(scenarios.medium);
        displayTaxDetail(scenarios.medium);
        displayFinalProfit(scenarios.medium, baseInputs);

        document.getElementById('loading').classList.remove('active');
        document.getElementById('results').classList.add('active');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
    }, 800);
}

function calculateScenario(inputs, scenarioName) {
    const gfa = inputs.landSize * inputs.plotRatio;
    const constructionCostTotal = gfa * inputs.constructionCost;
    const profFees = constructionCostTotal * inputs.profFees;
    const contingency = constructionCostTotal * inputs.contingency;
    const totalConstruction = constructionCostTotal + profFees + contingency + inputs.otherDevCosts;

    // Target IRR back-calculation for land price
    // We need to find land price such that project IRR = target IRR
    // Using iterative approach

    const landPrice = solveLandPrice(inputs, totalConstruction, gfa);

    const landLoan = landPrice * inputs.landLTV;
    const constructionLoan = totalConstruction * inputs.constructionLTV;
    const totalLoan = landLoan + constructionLoan;
    const totalEquity = landPrice + totalConstruction - totalLoan;

    // Loan schedules
    const landSchedule = calculateLoanSchedule(landLoan, inputs.landRate, inputs.landTenor);
    const constructionSchedule = calculateLoanSchedule(constructionLoan, inputs.constructionRate, inputs.constructionTenor);

    // Annual cashflow
    const years = inputs.leasehold;
    const annualData = [];
    let cumulativeCF = -totalEquity - inputs.equity;

    const buildingValue = constructionCostTotal + profFees + contingency;
    const annualDepreciation = buildingValue / Math.min(inputs.leasehold, 25);

    for (let y = 1; y <= years; y++) {
        const currentRent = inputs.rentalRate * Math.pow(1 + inputs.rentEscalation, y - 1);
        const grossRental = inputs.numPax * currentRent * 12;
        const vacancyLoss = grossRental * (1 - inputs.occupancy);
        const netRental = grossRental - vacancyLoss;

        const currentOpexPerPax = inputs.opexPerPax * Math.pow(1 + inputs.opexEscalation, y - 1);
        const variableOpex = inputs.numPax * currentOpexPerPax * 12;
        const fixedOpex = inputs.fixedOpex * Math.pow(1 + inputs.opexEscalation, y - 1) * 12;
        const totalOpex = variableOpex + fixedOpex;

        const ebitda = netRental - totalOpex;

        // IRAS Property Tax: 10% of AV, AV = 5% of gross rental for dormitories
        const annualValue = grossRental * 0.05;
        const propertyTax = annualValue * 0.10;

        // Loan interest for this year
        const startMonth = (y - 1) * 12 + 1;
        const endMonth = y * 12;
        let landInterest = 0, landPrincipal = 0;
        let constInterest = 0, constPrincipal = 0;

        for (let m = startMonth; m <= endMonth; m++) {
            const ls = landSchedule.find(s => s.month === m);
            if (ls) { landInterest += ls.interest; landPrincipal += ls.principal; }
            const cs = constructionSchedule.find(s => s.month === m);
            if (cs) { constInterest += cs.interest; constPrincipal += cs.principal; }
        }

        const totalInterest = landInterest + constInterest;
        const totalPrincipal = landPrincipal + constPrincipal;

        // Shareholder loan
        const shInterest = inputs.shLoanAmount * inputs.shLoanRate;
        const shPrincipal = y <= 10 ? inputs.shLoanAmount / 10 : 0;

        // Taxable income
        const taxableIncome = Math.max(0, ebitda - propertyTax - totalInterest - annualDepreciation - shInterest);
        const incomeTax = taxableIncome * 0.17;

        const netCashflow = ebitda - propertyTax - totalInterest - totalPrincipal - incomeTax - shInterest - shPrincipal;
        cumulativeCF += netCashflow;

        // Terminal value in final year
        let terminalValue = 0;
        if (y === years) {
            const exitNOI = (netRental - totalOpex - propertyTax) * 0.83; // After tax
            terminalValue = exitNOI / inputs.exitCapRate;
            cumulativeCF += terminalValue;
        }

        annualData.push({
            year: y,
            grossRental,
            vacancyLoss,
            netRental,
            totalOpex,
            ebitda,
            propertyTax,
            landInterest,
            constInterest,
            totalInterest,
            annualDepreciation,
            taxableIncome,
            incomeTax,
            landPrincipal,
            constPrincipal,
            totalPrincipal,
            shInterest,
            shPrincipal,
            netCashflow,
            cumulativeCF: cumulativeCF - (y === years ? terminalValue : 0),
            terminalValue,
            finalCumulative: cumulativeCF
        });
    }

    return {
        inputs,
        gfa,
        landPrice,
        constructionCostTotal,
        profFees,
        contingency,
        totalConstruction,
        landLoan,
        constructionLoan,
        totalEquity,
        landSchedule,
        constructionSchedule,
        annualData,
        buildingValue,
        annualDepreciation
    };
}

function solveLandPrice(inputs, totalConstruction, gfa) {
    // Binary search for land price that gives target IRR
    let low = 1e6, high = 5e9;
    let bestPrice = 0;

    for (let iter = 0; iter < 60; iter++) {
        const mid = (low + high) / 2;
        const landLoan = mid * inputs.landLTV;
        const constructionLoan = totalConstruction * inputs.constructionLTV;
        const equity = mid + totalConstruction - landLoan - constructionLoan;

        const irr = calculateIRR(inputs, mid, totalConstruction, landLoan, constructionLoan, equity);

        if (irr >= inputs.targetIRR) {
            bestPrice = mid;
            low = mid;
        } else {
            high = mid;
        }
    }

    return bestPrice || (low + high) / 2;
}

function calculateIRR(inputs, landPrice, totalConstruction, landLoan, constructionLoan, equity) {
    const landSchedule = calculateLoanSchedule(landLoan, inputs.landRate, inputs.landTenor);
    const constructionSchedule = calculateLoanSchedule(constructionLoan, inputs.constructionRate, inputs.constructionTenor);
    const buildingValue = totalConstruction * 0.85; // Approximate building portion
    const annualDepreciation = buildingValue / Math.min(inputs.leasehold, 25);

    const cashflows = [-equity - inputs.equity];

    for (let y = 1; y <= inputs.leasehold; y++) {
        const currentRent = inputs.rentalRate * Math.pow(1 + inputs.rentEscalation, y - 1);
        const grossRental = inputs.numPax * currentRent * 12;
        const vacancyLoss = grossRental * (1 - inputs.occupancy);
        const netRental = grossRental - vacancyLoss;

        const currentOpexPerPax = inputs.opexPerPax * Math.pow(1 + inputs.opexEscalation, y - 1);
        const variableOpex = inputs.numPax * currentOpexPerPax * 12;
        const fixedOpex = inputs.fixedOpex * Math.pow(1 + inputs.opexEscalation, y - 1) * 12;
        const totalOpex = variableOpex + fixedOpex;

        const ebitda = netRental - totalOpex;
        const annualValue = grossRental * 0.05;
        const propertyTax = annualValue * 0.10;

        const startMonth = (y - 1) * 12 + 1;
        const endMonth = y * 12;
        let totalInterest = 0, totalPrincipal = 0;

        for (let m = startMonth; m <= endMonth; m++) {
            const ls = landSchedule.find(s => s.month === m);
            if (ls) { totalInterest += ls.interest; totalPrincipal += ls.principal; }
            const cs = constructionSchedule.find(s => s.month === m);
            if (cs) { totalInterest += cs.interest; totalPrincipal += cs.principal; }
        }

        const shInterest = inputs.shLoanAmount * inputs.shLoanRate;
        const shPrincipal = y <= 10 ? inputs.shLoanAmount / 10 : 0;
        const taxableIncome = Math.max(0, ebitda - propertyTax - totalInterest - annualDepreciation - shInterest);
        const incomeTax = taxableIncome * 0.17;

        let cf = ebitda - propertyTax - totalInterest - totalPrincipal - incomeTax - shInterest - shPrincipal;

        if (y === inputs.leasehold) {
            const exitNOI = (netRental - totalOpex - propertyTax) * 0.83;
            cf += exitNOI / inputs.exitCapRate;
        }

        cashflows.push(cf);
    }

    return computeIRR(cashflows);
}

function computeIRR(cashflows) {
    let guess = 0.10;
    for (let iter = 0; iter < 100; iter++) {
        let npv = 0, dnpv = 0;
        for (let t = 0; t < cashflows.length; t++) {
            npv += cashflows[t] / Math.pow(1 + guess, t);
            dnpv -= t * cashflows[t] / Math.pow(1 + guess, t + 1);
        }
        if (Math.abs(npv) < 1) return guess;
        const newGuess = guess - npv / dnpv;
        if (Math.abs(newGuess - guess) < 1e-7) return newGuess;
        guess = newGuess;
    }
    return guess;
}

