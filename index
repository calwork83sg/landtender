function displayTaxDetail(data) {
    const tbody = document.querySelector('#taxTable tbody');
    tbody.innerHTML = '';

    data.annualData.forEach(row => {
        const totalDeductions = row.totalOpex + row.propertyTax + row.totalInterest + row.annualDepreciation + row.shInterest;
        const totalTax = row.incomeTax + row.propertyTax;
        const effectiveRate = row.grossRental > 0 ? (totalTax / row.grossRental * 100) : 0;

        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><strong>${row.year}</strong></td>
            <td>${formatCurrency(row.grossRental)}</td>
            <td>${formatCurrency(totalDeductions)}</td>
            <td>${formatCurrency(row.taxableIncome)}</td>
            <td>${formatCurrency(row.incomeTax)}</td>
            <td>${formatCurrency(row.propertyTax)}</td>
            <td>${formatCurrency(totalTax)}</td>
            <td>${effectiveRate.toFixed(2)}%</td>
        `;
        tbody.appendChild(tr);
    });
}

function displayFinalProfit(data, inputs) {
    const totalRevenue = data.annualData.reduce((sum, r) => sum + r.grossRental, 0) + (data.annualData[data.annualData.length-1]?.terminalValue || 0);
    const totalOpex = data.annualData.reduce((sum, r) => sum + r.totalOpex, 0);
    const totalInterest = data.annualData.reduce((sum, r) => sum + r.totalInterest, 0);
    const totalTax = data.annualData.reduce((sum, r) => sum + r.incomeTax + r.propertyTax, 0);
    const totalPrincipal = data.annualData.reduce((sum, r) => sum + r.totalPrincipal, 0);
    const totalSH = data.annualData.reduce((sum, r) => sum + r.shInterest + r.shPrincipal, 0);

    const netProfit = totalRevenue - totalOpex - totalInterest - totalTax - totalPrincipal - totalSH;

    document.getElementById('totalRevenue').textContent = formatCurrency(totalRevenue);
    document.getElementById('totalOpex').textContent = formatCurrency(totalOpex + totalPrincipal + totalSH);
    document.getElementById('totalInterest').textContent = formatCurrency(totalInterest);
    document.getElementById('totalTax').textContent = formatCurrency(totalTax);

    document.getElementById('finalProfit').textContent = formatCurrency(netProfit);
    document.getElementById('finalProfitSub').textContent = `Over ${inputs.leasehold}-year leasehold | ${formatCurrency(data.landPrice)} land price`;

    // NPV
    const cashflows = [-data.totalEquity - inputs.equity];
    data.annualData.forEach(r => cashflows.push(r.netCashflow + (r.terminalValue || 0)));
    let npv = 0;
    cashflows.forEach((cf, t) => { npv += cf / Math.pow(1 + inputs.targetIRR, t); });
    document.getElementById('npv').textContent = formatCurrency(npv);

    // Equity IRR
    const eqIRR = computeIRR(cashflows);
    document.getElementById('equityIRR').textContent = (eqIRR * 100).toFixed(2) + '%';

    // Cash multiple
    const totalIn = -cashflows[0];
    const totalOut = cashflows.slice(1).reduce((a, b) => a + b, 0);
    document.getElementById('cashMultiple').textContent = (totalOut / totalIn).toFixed(2) + 'x';
}

function renderCharts() {
    if (chartInstances.cashflow) chartInstances.cashflow.destroy();
    if (chartInstances.loan) chartInstances.loan.destroy();

    const years = cashflowData.annualData.map(d => 'Y' + d.year);
    const netCashflows = cashflowData.annualData.map(d => d.netCashflow / 1e6);
    const cumCashflows = cashflowData.annualData.map(d => d.cumulativeCF / 1e6);

    const ctx1 = document.getElementById('cashflowChart').getContext('2d');
    chartInstances.cashflow = new Chart(ctx1, {
        type: 'bar',
        data: {
            labels: years,
            datasets: [
                {
                    label: 'Net Cashflow (S$M)',
                    data: netCashflows,
                    backgroundColor: netCashflows.map(v => v >= 0 ? 'rgba(56, 161, 105, 0.7)' : 'rgba(229, 62, 62, 0.7)'),
                    borderColor: netCashflows.map(v => v >= 0 ? 'rgba(56, 161, 105, 1)' : 'rgba(229, 62, 62, 1)'),
                    borderWidth: 1,
                    yAxisID: 'y'
                },
                {
                    label: 'Cumulative (S$M)',
                    data: cumCashflows,
                    type: 'line',
                    borderColor: '#2c5282',
